KIMI_API_KEY=your_moonshot_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_BASE_URL=https://your-public-url.com
# Email (Gmail SMTP) — generate app password at: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=Bob Agent
# Optional failover model (leave empty to disable failover chain)
KIMI_FALLBACK_MODEL=
# Enable/disable primary->fallback failover logic (default true)
LLM_FAILOVER_ENABLED=true
# LLM request timeout in seconds (default 120)
LLM_REQUEST_TIMEOUT_SECONDS=120
# Circuit breaker for external providers
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
# Policy preset: dev | staging | prod
POLICY_PACK=dev
# Global autonomy preset: openclaw_max | standard
AUTONOMY_MODE=openclaw_max
# Optional explicit full-power override (high risk): false | true
BOB_FULL_POWER_ENABLED=false
# Full-power scope: workspace | system
BOB_FULL_POWER_SCOPE=workspace
# Custom tool trust mode: safe | full
CUSTOM_TOOL_TRUST_MODE=safe
# Budget governor: warn | degrade | stop
BUDGET_GOVERNOR_ENABLED=true
BUDGET_GOVERNOR_MODE=degrade
BUDGET_MAX_SECONDS=180
BUDGET_MAX_TOOL_CALLS=40
BUDGET_MAX_LLM_CALLS=24
BUDGET_MAX_EST_TOKENS=90000
BUDGET_DEGRADE_AT_PERCENT=80
# Command queue mode for inbound chat messages: off | on | auto
COMMAND_QUEUE_MODE=on
# Max queued inbound chat jobs before new jobs are dropped
COMMAND_QUEUE_MAX_SIZE=200
# AUTO mode: enqueue when global backlog reaches this threshold
COMMAND_QUEUE_AUTO_BACKPRESSURE=1
# Number of concurrent queue workers
COMMAND_QUEUE_WORKER_COUNT=2
# Per-lane concurrency caps (semicolon-separated lane:limit)
COMMAND_QUEUE_LANE_LIMITS=default:2;research:1;api:2;telegram:2;cron:1
# Tool policy profile: safe | balanced | power
TOOL_POLICY_PROFILE=power
# Optional extra write roots for balanced/safe policies (semicolon-separated absolute paths)
TOOL_POLICY_WRITE_ROOTS=
# Execution sandbox profile: strict | default | power
EXECUTION_SANDBOX_PROFILE=power
# Optional comma-separated remote node allowlist for run_command_node (empty = any configured remote)
EXECUTION_SANDBOX_REMOTE_ALLOWLIST=
# Optional additional regex deny patterns (comma-separated) for shell and python execution
EXECUTION_SANDBOX_BLOCK_COMMAND_PATTERNS=
EXECUTION_SANDBOX_BLOCK_PYTHON_PATTERNS=
# Optional OS/container sandbox for local exec tools: off | docker
OS_SANDBOX_MODE=docker
OS_SANDBOX_REQUIRED=true
WORKSPACE_SESSION_ISOLATION_ENABLED=true
WORKSPACE_SESSION_ROOT=mind-clone/persist/workspaces
# Tool path resolution: stabilize relative paths for file tools + cwd defaults
TOOL_PATH_RESOLUTION_ENABLED=true
# auto | repo | core | off
TOOL_PATH_RESOLUTION_MODE=auto
# Default cwd when run_command/execute_python omit cwd: auto | repo | core | process
TOOL_DEFAULT_CWD_MODE=auto
OS_SANDBOX_DOCKER_IMAGE=python:3.11-slim
OS_SANDBOX_DOCKER_NETWORK=none
OS_SANDBOX_DOCKER_CPUS=1.0
OS_SANDBOX_DOCKER_MEMORY_MB=512
OS_SANDBOX_TIMEOUT_BUFFER_SECONDS=8
# Desktop control (OpenClaw-style host UI automation)
DESKTOP_CONTROL_ENABLED=true
DESKTOP_FAILSAFE_ENABLED=false
DESKTOP_ACTION_PAUSE_SECONDS=0.05
DESKTOP_DEFAULT_MOVE_DURATION=0.08
DESKTOP_DEFAULT_TYPE_INTERVAL=0.01
# Relative paths resolve from current workspace root
DESKTOP_SCREENSHOT_DIR=mind-clone/persist/desktop/screenshots
DESKTOP_SESSION_DIR=mind-clone/persist/desktop/sessions
DESKTOP_REQUIRE_ACTIVE_SESSION=false
DESKTOP_REPLAY_MAX_STEPS=800
DESKTOP_IMAGE_MATCH_THRESHOLD=0.86
DESKTOP_UITREE_DEFAULT_LIMIT=80
# Ops auth wall for debug/cron/plugin-control endpoints
OPS_AUTH_ENABLED=false
OPS_AUTH_TOKEN=
OPS_AUTH_ALLOWED_ROLES=owner,operator
OPS_AUTH_REQUIRE_SIGNATURE=false
OPS_AUTH_SIGNATURE_SKEW_SECONDS=60
# Optional per-role signature secrets format: owner=secret;operator=secret;default=fallback
OPS_AUTH_ROLE_SECRETS=
# Approval gate mode: off | balanced | strict
APPROVAL_GATE_MODE=off
# Approval token TTL in minutes
APPROVAL_TOKEN_TTL_MINUTES=240
# Tools requiring approval in balanced mode (comma-separated)
APPROVAL_REQUIRED_TOOLS=run_command,execute_python,write_file,run_command_node
# Workspace diff gate for write_file: warn | approval | block
WORKSPACE_DIFF_GATE_ENABLED=true
WORKSPACE_DIFF_GATE_MODE=warn
WORKSPACE_DIFF_MAX_CHANGED_LINES=260
WORKSPACE_DIFF_MAX_FILE_BYTES=350000
WORKSPACE_DIFF_MONITORED_EXTENSIONS=.py,.ts,.tsx,.js,.jsx,.json,.yaml,.yml,.md,.toml,.ini,.env,.txt
# Secret redaction guardrail for logs/tool payloads
SECRET_GUARDRAIL_ENABLED=true
SECRET_REDACTION_TOKEN=[REDACTED]
SECRET_REDACTION_MAX_HITS=50
# Task graph orchestration controls
TASK_GRAPH_BRANCHING_ENABLED=true
TASK_GRAPH_MAX_NODES=24
TASK_GRAPH_MAX_BRANCHES_PER_NODE=1
# Long-term task artifact memory controls
TASK_ARTIFACT_RETRIEVE_TOP_K=3
TASK_ARTIFACT_MAX_PER_USER=600
TASK_ARTIFACT_VECTOR_SCAN_LIMIT=1200
# Session pruning / compaction context controls
SESSION_SOFT_TRIM_ENABLED=true
SESSION_SOFT_TRIM_CHAR_BUDGET=42000
SESSION_SOFT_TRIM_KEEP_RECENT=28
SESSION_SOFT_TRIM_TOOL_MAX_CHARS=1600
SESSION_HARD_CLEAR_CHAR_BUDGET=30000
SESSION_HARD_CLEAR_TOOL_MAX_CHARS=240
SESSION_HARD_CLEAR_KEEP_RECENT=16
SESSION_MEMORY_FLUSH_BEFORE_COMPACTION=true
SESSION_MEMORY_FLUSH_CHECKPOINT=true
# World-model prediction/reconciliation memory controls
WORLD_MODEL_RETRIEVE_TOP_K=3
WORLD_MODEL_VECTOR_SCAN_LIMIT=1200
WORLD_MODEL_MAX_FORECASTS_PER_USER=600
WORLD_MODEL_RECENT_ACCURACY_WINDOW=60
# Self-improvement loop controls
SELF_IMPROVE_INTERVAL_SECONDS=1800
SELF_IMPROVE_MAX_NOTES_PER_USER=300
SELF_IMPROVE_RETRIEVE_TOP_K=2
# Dormant capability activation controls
CAPABILITY_ACTIVATION_TTL_SECONDS=21600
CAPABILITY_MAX_EVENTS_PER_USER=600
# Orphan task recovery guardrails
TASK_GUARD_ORPHAN_LEASE_SECONDS=300
TASK_GUARD_MAX_ORPHAN_RECOVERIES=3
# Idempotent /task dedupe window (seconds)
TASK_DEDUPE_WINDOW_SECONDS=1800
# Remote node registry as JSON array
# Example: [{"name":"lab1","base_url":"https://node1.example.com","token":"secret","command_path":"/run_command","enabled":true}]
REMOTE_NODES_JSON=[]
REMOTE_NODE_TIMEOUT_SECONDS=45
NODE_CONTROL_PLANE_ENABLED=true
NODE_HEARTBEAT_STALE_SECONDS=90
NODE_LEASE_TTL_SECONDS=180
NODE_AUTO_CAPABILITY_DEFAULT=general
NODE_SCHEDULER_LEASE_PENALTY=4.0
NODE_SCHEDULER_FAILURE_PENALTY=16.0
NODE_SCHEDULER_LATENCY_PENALTY=0.015
NODE_SCHEDULER_RECOVERY_BONUS=12.0
NODE_SCHEDULER_FAILURE_WINDOW_SECONDS=300
# Dynamic plugin tools
PLUGIN_ENABLE_DYNAMIC_TOOLS=true
MIND_CLONE_PLUGIN_DIR=mind-clone/plugins
# Optional allowlist of plugin IDs (comma-separated). Empty = allow all manifests that pass trust checks.
PLUGIN_ALLOWLIST=
# Optional pinned versions format: plugin_id=version;plugin2=version
PLUGIN_PINNED_VERSIONS=
# Optional trusted manifest hashes format: plugin_id=sha256;plugin2=sha256
PLUGIN_TRUSTED_HASHES=
# If true, plugins without matching trusted hash are blocked
PLUGIN_ENFORCE_TRUST=false
# Skills-first runtime (versioned skill vault + auto-skill synthesis)
SKILLS_ENABLED=true
SKILLS_AUTO_CREATE_ENABLED=true
SKILLS_AUTO_ACTIVATE_ENABLED=true
SKILLS_MAX_PER_OWNER=120
SKILLS_MAX_BODY_CHARS=5000
SKILLS_ACTIVE_TOP_K=3
SKILLS_AUTO_CREATE_COOLDOWN_SECONDS=600
SKILLS_VAULT_ROOT=mind-clone/persist/skills_vault
# Session-lane observability retention window
SESSION_LANE_STALE_SECONDS=3600
# Structured JSON llm-task helper
LLM_STRUCTURED_TASK_ENABLED=true
LLM_STRUCTURED_TASK_MAX_ATTEMPTS=2
# Cron / scheduled autonomous jobs
CRON_ENABLED=true
CRON_TICK_SECONDS=10
CRON_MIN_INTERVAL_SECONDS=60
CRON_MAX_DUE_PER_TICK=10
# Optional startup jobs JSON array with owner_id/name/message/interval_seconds/lane
CRON_BOOTSTRAP_JOBS_JSON=[]
# Heartbeat autonomy supervisor
HEARTBEAT_AUTONOMY_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=45
# Live event stream (SSE) polling defaults
EVENT_STREAM_POLL_SECONDS=1.0
EVENT_STREAM_BATCH_SIZE=120
# Task role loop: off | linear | cycle
TASK_ROLE_LOOP_ENABLED=true
TASK_ROLE_LOOP_MODE=linear
# Continuous eval harness
EVAL_HARNESS_ENABLED=true
EVAL_MAX_CASES=16
EVAL_AUTORUN_EVERY_TICKS=0
RELEASE_GATE_MIN_PASS_RATE=1.0
RELEASE_GATE_REQUIRE_ZERO_FAILS=true
# Workflow v2 controls
WORKFLOW_V2_ENABLED=true
WORKFLOW_LOOP_MAX_ITERATIONS=8
# Persistent SQLite path (recommended: outside OneDrive/temp)
MIND_CLONE_DB_PATH=C:\Users\mader\.mind-clone\mind_clone.db
# Deterministic checkpoints and usage ledger
TASK_CHECKPOINT_SNAPSHOT_ENABLED=true
TASK_CHECKPOINT_MAX_PER_TASK=180
TASK_CHECKPOINT_REPLAY_STRICT=true
TASK_CHECKPOINT_SCHEMA_VERSION=2
USAGE_LEDGER_ENABLED=true
USAGE_DEFAULT_INPUT_COST_PER_1K=0.003
USAGE_DEFAULT_OUTPUT_COST_PER_1K=0.006
# Optional per-model overrides format: model=input_cost,output_cost;model2=...
USAGE_MODEL_COST_OVERRIDES=
# Canary model router
CANARY_ROUTER_ENABLED=false
CANARY_PROFILE_NAME=canary
CANARY_TRAFFIC_PERCENT=10
CANARY_MIN_SAMPLES=30
CANARY_FAIL_THRESHOLD=0.35
CANARY_ROLLBACK_COOLDOWN_SECONDS=900
# Black box execution recorder
BLACKBOX_ENABLED=true
BLACKBOX_PAYLOAD_MAX_CHARS=6000
BLACKBOX_READ_MAX_LIMIT=200
# Black box session diagnostics
BLACKBOX_SESSION_LIST_MAX_LIMIT=100
BLACKBOX_SESSION_REPORT_MAX_EVENTS=500
BLACKBOX_SESSION_FAILURE_SAMPLE_LIMIT=6
# Black box recovery planning
BLACKBOX_RECOVERY_MAX_APPROVALS=25
BLACKBOX_RECOVERY_MAX_ACTIONS=12
# Black box retention / export controls
BLACKBOX_PRUNE_ENABLED=true
BLACKBOX_MAX_EVENTS_PER_OWNER=20000
BLACKBOX_MAX_EVENT_AGE_DAYS=30
BLACKBOX_PRUNE_BATCH_SIZE=2000
BLACKBOX_PRUNE_INTERVAL_SECONDS=300
BLACKBOX_EXPORT_MAX_EVENTS=1000

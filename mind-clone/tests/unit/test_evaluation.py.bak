class TestBFCLBenchmark:

    def test_all_bfcl_cases_pass(self):
        result = run_continuous_eval_suite()
        bfcl = result["benchmarks"].get("bfcl", {})
        assert bfcl.get("failed", 0) == 0, f"BFCL failures: {bfcl}"



# ---------------------------------------------------------------------------
# evaluate_release_gate
# ---------------------------------------------------------------------------

class TestReleaseGate:

    def test_no_eval_passes_by_default(self):
        result = evaluate_release_gate(run_eval=False)
        assert result["passed"] is True
        assert result["eval_result"] == {}

    def test_with_eval_passes_when_all_pass(self):
        """All cases pass → release gate passes."""
        result = evaluate_release_gate(run_eval=True)
        assert result["passed"] is True

    def test_returns_expected_keys(self):
        result = evaluate_release_gate()
        assert "ok" in result
        assert "passed" in result
        assert "eval_result" in result
        assert "timestamp" in result

    def test_ok_always_true(self):
        result = evaluate_release_gate(run_eval=True)
        assert result["ok"] is True

    def test_max_cases_passed_through(self):
        result = evaluate_release_gate(run_eval=True, max_cases=5)
        assert result["passed"] is True
        assert result["eval_result"]["cases_run"] == 5

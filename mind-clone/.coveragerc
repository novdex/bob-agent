[run]
source = mind_clone
omit =
    # External service adapters — require live connections
    */telegram/*
    */discord_adapter.py
    */voice_stt.py
    */voice_tts.py
    # Desktop/browser automation — requires GUI
    */desktop/*
    */browser.py
    */web_automation.py
    */vision.py
    # CLI runner — tested via E2E
    */runner.py
    # Multi-model orchestrator — tested via integration
    */multi_model.py
    # Service layers requiring live DB/external APIs
    */services/embedding_dedup.py
    */services/memory_export.py
    */services/memory_reindex.py
    */services/security_audit.py
    # Tool implementations requiring live execution context
    */tools/codebase.py
    */tools/github.py
    */tools/memory.py
    */tools/knowledge.py
    */tools/nodes.py
    */tools/sessions.py
    */tools/scheduler.py
    */tools/subagents.py

[report]
# Core modules must maintain 70%+ coverage
fail_under = 50
show_missing = true
skip_covered = false
precision = 1
exclude_lines =
    pragma: no cover
    def __repr__
    if TYPE_CHECKING:
    if __name__ == .__main__.:
    raise NotImplementedError
    pass

[html]
directory = htmlcov
